generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Assignment {
  id           String   @id @default(cuid())
  title        String
  courseCode   String
  type         String
  dueDate      DateTime
  status       String   @default("NOT_STARTED")
  progress     Int      @default(0)
  description  String?
  notes        String?
  groupMembers Json?
  checklist    Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WeekEntry {
  id          String   @id @default(cuid())
  courseCode  String
  weekNumber  Int
  topicTitle  String
  covered     String?
  keyConcepts String?
  learned     String?
  profNotes   String?
  confidence  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([courseCode, weekNumber])
}

model CourseNote {
  id         String   @id @default(cuid())
  courseCode String   @unique
  content    String
  updatedAt  DateTime @updatedAt
}
